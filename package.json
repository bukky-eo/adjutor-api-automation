{
  "name": "adjutor-automation",
  "version": "1.0.0",
  "scripts": {
    "test": "jest --verbose",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "jest": "^29.0.0"
  },
  "devDependencies": {
    "jest-html-reporter": "^4.4.0",
    "joi": "^18.1.2"
  }
}
